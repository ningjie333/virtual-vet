        </mxCell>

        <!-- Saturation plateau line (red dotted) -->
        <mxCell id="f2-30" value="" style="line;html=1;strokeColor=#D55E00;strokeWidth=1;dashed=1;dashPattern=3 3;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="37" width="440" height="10" />
        </mxCell>
        <mxCell id="f2-31" value="Saturation plateau (144.7 mmHg)" style="text;html=1;align=left;verticalAlign=middle;fontSize=8;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="410" y="27" width="100" height="15" />
        </mxCell>

        <!-- Annotations -->
        <mxCell id="f2-32" value="Unsaturated&amp;nbsp;&lt;br&gt;(bias ∝ 1/dt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#006BA6;strokeWidth=1;fontSize=9;fontFamily=Times New Roman;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="165" y="155" width="90" height="35" />
