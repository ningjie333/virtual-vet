  <diagram name="Figure 1 — Spurious Steady State Schematic" id="page-fig1">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="550" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ════ Figure title ════ -->
        <mxCell id="f1-2" value="Figure 1: Spurious Steady State — Drift and Saturation Mechanism" style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="10" width="950" height="30" />
