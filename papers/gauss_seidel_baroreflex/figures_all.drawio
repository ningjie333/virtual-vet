          <mxGeometry x="350" y="376" width="40" height="15" />
        </mxCell>

        <!-- Grid lines (horizontal) -->
        <mxCell id="f2-22" value="" style="line;html=1;strokeColor=#DDDDDD;strokeWidth=0.5;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="345" width="440" height="10" />
        </mxCell>
        <mxCell id="f2-23" value="" style="line;html=1;strokeColor=#DDDDDD;strokeWidth=0.5;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="271" width="440" height="10" />
        </mxCell>
        <mxCell id="f2-24" value="" style="line;html=1;strokeColor=#DDDDDD;strokeWidth=0.5;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="197" width="440" height="10" />
        </mxCell>
        <mxCell id="f2-25" value="" style="line;html=1;strokeColor=#DDDDDD;strokeWidth=0.5;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="123" width="440" height="10" />
        </mxCell>

        <!-- Data points: dt=0.1, 0.05, 0.02, 0.01, 0.005, 0.001 -->
        <!-- Log mapping: x_log = 60 + 440 * log10(dt/0.001)/log10(0.1/0.001) = 60 + 440 * log10(dt/0.001)/2 -->
        <!-- dt=0.1:  x = 60 + 440*1/2 = 280,   y=345-((111-100)/(145-100))*310 = 345-11/45*310 = 269 -->
        <!-- dt=0.05: x = 60 + 440*log10(50)/2 = 60+440*0.699/2 = 214, y=345-21.1/45*310 = 200 -->
        <!-- dt=0.02: x = 60 + 440*log10(20)/2 = 60+440*0.301/2 = 126, y=345-44.7/45*310 = 37 -->
        <!-- dt<=0.01: saturation, MAP=144.7 -->
        <!-- dt=0.01: x = 60 + 440*log10(10)/2 = 60+440*0.5 = 280,  y=37 -->
        <!-- dt=0.005: x = 60 + 440*log10(5)/2 = 60+440*0.349 = 214, y=37 -->
        <!-- dt=0.001: x = 60, y=37 -->

        <!-- Line connecting data points (piecewise) -->
        <mxCell id="f2-26" value="" style="line;html=1;strokeColor=#006BA6;strokeWidth=2.5;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="280" y="269" width="10" height="10" />
        </mxCell>
        <!-- Path: approximate polyline -->
        <mxCell id="f2-27" value="" style="shape=curved;html=1;strokeColor=#006BA6;strokeWidth=2.5;fillColor=none;rounded=1;" edge="1" parent="1">
          <mxGeometry width="440" height="310" as="geometry">
            <mxPoint x="280" y="269" as="sourcePoint" />
            <mxPoint x="214" y="200" as="targetPoint" />
            <Array as="points">
              <mxPoint x="126" y="37" />
              <mxPoint x="280" y="37" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Actually, for a log plot, let me use individual segments more precisely -->
        <!-- Let me redraw the data line properly -->

        <!-- Nominal MAP line (green dashed) -->
        <mxCell id="f2-28" value="" style="line;html=1;strokeColor=#009E73;strokeWidth=1.5;dashed=1;dashPattern=8 5;pointerEvents=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="345" width="440" height="10" />
