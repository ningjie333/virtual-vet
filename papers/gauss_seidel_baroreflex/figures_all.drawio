        <!-- ════ Panel labels ════ -->
        <mxCell id="f1-3" value="A" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontFamily=Helvetica;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="30" height="20" />
        </mxCell>
        <mxCell id="f1-4" value="B" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontFamily=Helvetica;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="220" width="30" height="20" />
        </mxCell>
        <mxCell id="f1-5" value="C" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontFamily=Helvetica;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="30" height="20" />
        </mxCell>
        <mxCell id="f1-6" value="D" style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontStyle=1;fontFamily=Helvetica;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="30" y="420" width="30" height="20" />
        </mxCell>

        <!-- ════ Node 1: True Fixed Point (Top-Left) ════ -->
        <mxCell id="f1-10" value="&lt;b&gt;True Fixed Point&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#666;&quot;&gt;MAP ≈ 100 mmHg&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F0FE;strokeColor=#006BA6;strokeWidth=2;fontSize=11;fontFamily=Times New Roman;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="65" width="210" height="70" />
        </mxCell>

        <!-- ════ Node 2: Spurious Fixed Point (Top-Right) ════ -->
        <mxCell id="f1-11" value="&lt;b&gt;Spurious Fixed Point&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#666;&quot;&gt;MAP ≈ 144.7 mmHg&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0E8;strokeColor=#D55E00;strokeWidth=2;fontSize=11;fontFamily=Times New Roman;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="65" width="210" height="70" />
        </mxCell>

        <!-- ════ Node 3: HR Saturation (Mid-Right) ════ -->
        <mxCell id="f1-12" value="&lt;b&gt;HR Saturation at 180 bpm&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#666;&quot;&gt;physiological ceiling truncates drift&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#c8860a;strokeWidth=2;fontSize=11;fontFamily=Times New Roman;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="600" y="230" width="250" height="70" />
        </mxCell>

        <!-- ════ Node 4: Continuous Baroreflex Path (Bottom-Left) ════ -->
        <mxCell id="f1-13" value="&lt;b&gt;Continuous Baroreflex Path&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#666;&quot;&gt;HR_delta = (symp + para + chemo) × dt → correct&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#009E73;strokeWidth=2;fontSize=11;fontFamily=Times New Roman;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="110" y="395" width="220" height="70" />
        </mxCell>

        <!-- ════ Node 5: Discrete FC Path (Bottom-Right) ════ -->
        <mxCell id="f1-14" value="&lt;b&gt;Discrete FC Path (buggy)&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#666;&quot;&gt;net_HR_add = K bpm/step → K × T/dt total injection&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF0E8;strokeColor=#D55E00;strokeWidth=2;fontSize=11;fontFamily=Times New Roman;arcSize=14;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="610" y="395" width="230" height="70" />
        </mxCell>

        <!-- ════ Arrow 1: True FP → Spurious FP (main drift arrow) ════ -->
        <mxCell id="f1-20" value="&lt;b&gt;drift ∝ K × T / dt&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;font-size:8.5px;font-style:italic;&quot;&gt;(FC emission as bpm/step, not bpm/s)&lt;/span&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;endArrow=classic;endFill=1;strokeColor=#D55E00;strokeWidth=2.5;fontSize=10;fontFamily=Times New Roman;align=center;verticalAlign=middle;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="f1-10" target="f1-11">
          <mxGeometry x="0.5" y="-10" relative="1" as="geometry">
            <mxPoint as="offset" x="0" y="-30" />
          </mxGeometry>
        </mxCell>

        <!-- ════ Arrow 2: HR Sat → Spurious FP ════ -->
        <mxCell id="f1-21" value="&lt;i&gt;truncates drift&lt;/i&gt;" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;endArrow=classic;endFill=1;strokeColor=#c8860a;strokeWidth=1.8;fontSize=9;fontFamily=Times New Roman;align=left;verticalAlign=middle;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="f1-12" target="f1-11">
          <mxGeometry x="0.5" relative="1" as="geometry">
            <mxPoint x="-60" y="20" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- ════ Arrow 3: Cont Baro → True FP (dashed green) ════ -->
        <mxCell id="f1-22" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;endArrow=classic;endFill=1;strokeColor=#009E73;strokeWidth=1.5;dashed=1;dashPattern=8 5;" edge="1" parent="1" source="f1-13" target="f1-10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════ Arrow 4: Disc FC → HR Sat (dashed red) ════ -->
        <mxCell id="f1-23" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;endArrow=classic;endFill=1;strokeColor=#D55E00;strokeWidth=1.5;dashed=1;dashPattern=8 5;" edge="1" parent="1" source="f1-14" target="f1-12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ════ Legend box ════ -->
        <mxCell id="f1-30" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;── correct path&lt;br&gt;─ ─ error propagation&lt;br&gt;&lt;span style=&quot;color:#D55E00;&quot;&gt;● buggy/incorrect&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color:#009E73;&quot;&gt;● correct&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;strokeWidth=1;fontSize=9;fontFamily=Times New Roman;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="480" width="120" height="60" />
        </mxCell>

        <!-- ════ Section A subtitle ════ -->
        <mxCell id="f1-31" value="&lt;span style=&quot;font-size:9px;color:#888;&quot;&gt;Module A: continuous relaxation keeps x at setpoint&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;fontFamily=Times New Roman;fillColor=none;strokeColor=none;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="135" width="280" height="20" />
        </mxCell>

        <!-- ════ Section B subtitle ════ -->
        <mxCell id="f1-32" value="&lt;span style=&quot;font-size:9px;color:#888;&quot;&gt;Module B: threshold-gated FC emission, K bpm/step&lt;/span&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=9;fontFamily=Times New Roman;fillColor=none;strokeColor=none;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="280" height="20" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Figure 2 — MAP Bias vs dt" id="page-fig2">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="480" math="0" shadow="0">
