        <mxCell id="f2-33" value="Saturated&amp;nbsp;&lt;br&gt;(MAP plateau)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D55E00;strokeWidth=1;fontSize=9;fontFamily=Times New Roman;arcSize=8;" vertex="1" parent="1">
