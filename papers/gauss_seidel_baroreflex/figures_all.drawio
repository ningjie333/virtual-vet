        <mxCell id="f2-15" value="110" style="text;html=1;align=right;verticalAlign=middle;fontSize=8;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="25" y="276" width="30" height="15" />
        </mxCell>
        <mxCell id="f2-16" value="120" style="text;html=1;align=right;verticalAlign=middle;fontSize=8;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
