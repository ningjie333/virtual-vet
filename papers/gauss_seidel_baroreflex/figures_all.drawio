        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Panel (b): Dimensional analysis — right half -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="f2-40" value="(b) Dimensional Analysis — bias ∝ 1/dt (log-log)" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
