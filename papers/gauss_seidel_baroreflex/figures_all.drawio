        <mxCell id="f2-17" value="130" style="text;html=1;align=right;verticalAlign=middle;fontSize=8;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="25" y="128" width="30" height="15" />
        </mxCell>
        <mxCell id="f2-18" value="140" style="text;html=1;align=right;verticalAlign=middle;fontSize=8;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="25" y="74" width="30" height="15" />
        </mxCell>

        <!-- X-axis tick labels (log positions) -->
        <mxCell id="f2-19" value="0.001" style="text;html=1;align=center;verticalAlign=top;fontSize=8;fontFamily=Times New Roman;fillColor=none;strokeColor=none;" vertex="1" parent="1">
