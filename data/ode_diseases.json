{"_schema":"ode_diseases v1","_comment":"所有 'fn' 字段为 Python 表达式字符串。可用变量：状态变量名、params 键名、engine 字典（引擎状态快照）。clamp 格式 [lo, hi]，null 表示无界。ode_type: logistic | algebraic | first_order_lag | custom。","pneumonia":{"display_name":"肺炎（肺部感染）","severity_presets":{"mild":{"bacterial_seed":0.1,"growth_rate":0.02,"exudate_K":0.4,"immune_clearance":0.015},"moderate":{"bacterial_seed":0.3,"growth_rate":0.035,"exudate_K":0.7,"immune_clearance":0.01},"severe":{"bacterial_seed":0.6,"growth_rate":0.05,"exudate_K":0.95,"immune_clearance":0.005}},"state_variables":{"alveolar_exudate":{"initial":0.0,"clamp":[0,1],"ode_type":"logistic","params":{"rate":0.005,"K_key":"exudate_K","seed_threshold":0.01,"seed_boost_fn":"0.001 * min(bacterial_load / (bacterial_load + 1.0), 1.0)"}},"bacterial_load":{"initial_key":"bacterial_seed","clamp":[0,null],"ode_type":"custom","derivative_fn":"(growth_rate - immune_clearance * (1 + 0.5 * fever_state)) * bacterial_load"},"fever_state":{"initial":0.0,"clamp":[0,1],"ode_type":"first_order_lag","params":{"tau":1800.0,"target_fn":"min(bacterial_load / (bacterial_load + 2.0), 1.0)"}},"tissue_hypoxia":{"initial":0.0,"clamp":[0,1],"ode_type":"first_order_lag","params":{"tau":600.0,"target_fn":"min(alveolar_exudate ** 2.0 + min(bacterial_load / (bacterial_load + 5.0), 0.3), 1.0)"}}},"outputs":[{"target":"lung.diffusion_coefficient","op":"multiply","fn":"max(0.1, 1.0 - alveolar_exudate * 0.9)"},{"target":"heart.heart_rate","op":"add","fn":"fever_state * 20.0"},{"target":"heart.SVR","op":"multiply","fn":"max(0.5, 1.0 - 0.5 * min(max(tissue_hypoxia - 0.6, 0.0) / 0.4, 1.0))","condition":"tissue_hypoxia > 0.6"}]},"acute_renal_failure":{"display_name":"急性肾衰竭","severity_presets":{"mild":{"damage_rate":0.005,"damage_K":0.4},"moderate":{"damage_rate":0.008,"damage_K":1.0},"severe":{"damage_rate":0.02,"damage_K":0.95}},"state_variables":{"nephron_damage":{"initial":0.05,"clamp":[0,1],"ode_type":"logistic","params":{"rate_key":"damage_rate","K_key":"damage_K","seed_threshold"