{
  "pneumonia": {
    "guidelines": [
      {
        "authors": "Lappin MR, Blondeau J, Boothe D, et al.",
        "year": 2017,
        "title": "Antimicrobial use Guidelines for Treatment of Respiratory Tract Disease in Dogs and Cats",
        "journal": "J Vet Intern Med",
        "doi": "10.1111/jvim.14627",
        "type": "consensus"
      },
      {
        "authors": "Dear JD",
        "year": 2020,
        "title": "Bacterial Pneumonia in Dogs and Cats: An Update",
        "journal": "Vet Clin North Am Small Anim Pract",
        "pmid": "PMC7114575",
        "type": "review"
      }
    ],
    "criteria": {
      "PaO2_low": {"threshold": "<80 mmHg", "source": "Dear 2020", "mechanism": "V/Q mismatch from alveolar exudate"},
      "PaCO2_high": {"threshold": ">50 mmHg", "source": "Dear 2020", "mechanism": "Respiratory failure / hypoventilation"},
      "wbc_high": {"threshold": "Leukocytosis in 66%", "source": "Helsinki thesis; Dear 2020", "mechanism": "Systemic inflammatory response"},
      "rr_high": {"threshold": "Compensatory tachypnea", "source": "Dear 2020", "mechanism": "Compensate for hypoxemia"},
      "temp_high": {"threshold": ">39.5°C", "source": "Dear 2020", "mechanism": "Pyrogen release from infection"},
      "lung_exudate_xray": {"threshold": "Alveolar pattern", "source": "Dear 2020", "mechanism": "Alveolar filling with inflammatory cells"},
      "crackles": {"threshold": "Audible on auscultation", "source": "Dear 2020", "mechanism": "Fluid in alveoli"}
    },
    "treatment_basis": {
      "fluid_bolus": {"rationale": "Restore perfusion, careful to avoid fluid overload worsening pulmonary edema", "source": "ISCAID 2017"}
    }
  },
  "acute_renal_failure": {
    "guidelines": [
      {
        "authors": "Segev G, Cortellini S, Foster JD, et al.",
        "year": 2024,
        "title": "IRIS Best Practice Consensus Guidelines for AKI in Cats and Dogs",
        "journal": "Vet J",
        "doi": "10.1016/j.tvjl.2024.106068",
        "type": "consensus"
      }
    ],
    "criteria": {
      "gfr_low": {"threshold": "<50 mL/min", "source": "IRIS 2024", "mechanism": "Nephron loss reduces filtration"},
      "bun_high": {"threshold": ">30 mg/dL", "source": "IRIS 2024", "mechanism": "Impaired renal excretion + catabolism"},
      "potassium_high": {"threshold": ">5.5 mEq/L", "source": "IRIS 2024", "mechanism": "Impaired renal K+ excretion, oliguria"},
      "ph_low": {"threshold": "<7.35", "source": "IRIS 2024", "mechanism": "Impaired H+ excretion, reduced HCO3- reabsorption"},
      "cr_high": {"threshold": "≥0.3 mg/dL rise from baseline", "source": "IRIS 2024", "mechanism": "Primary AKI grading biomarker"},
      "usg_low": {"threshold": "<1.030 with azotemia", "source": "IRIS 2024", "mechanism": "Loss of concentrating ability"},
      "t_wave_tall": {"threshold": "K+ 5.5-6.0", "source": "Iimori 2026; Today's Vet Pract 2022", "mechanism": "Accelerated repolarization from elevated extracellular K+"},
      "qrs_wide": {"threshold": "K+ 6.5-7.0", "source": "Iimori 2026", "mechanism": "Slowed ventricular conduction"}
    },
    "iris_grading": {
      "I": {"creatinine_mg_dl": "<1.4", "description": "Non-azotemic AKI"},
      "II": {"creatinine_mg_dl": "1.4-2.8", "description": "Mild azotemia"},
      "III": {"creatinine_mg_dl": "2.9-5.0", "description": "Moderate azotemia"},
      "IV": {"creatinine_mg_dl": "5.1-10.0", "description": "Severe azotemia"},
      "V": {"creatinine_mg_dl": ">10.0", "description": "End-stage"}
    }
  },
  "dilated_cardiomyopathy": {
    "guidelines": [
      {
        "authors": "Fuentes VL, Abbott J, Chetboul V, et al.",
