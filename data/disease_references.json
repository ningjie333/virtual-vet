      }
    ],
    "diagnostic_triad": {
      "D": "Hyperglycemia ≥250 mg/dL",
      "K": "Ketonemia BHB ≥3.5-3.8 mmol/L",
      "A": "Metabolic acidosis pH <7.3, HCO3- <15"
    },
    "criteria": {
      "hr_high": {"threshold": "Tachycardia", "source": "Gal 2023", "mechanism": "Dehydration, compensatory"},
      "map_low": {"threshold": "Hypotension", "source": "Gal 2023", "mechanism": "Dehydration (5-10%), osmotic diuresis"},
      "rr_high": {"threshold": "Kussmaul respiration", "source": "Gal 2023; de Morais & DiBartola", "mechanism": "Respiratory compensation for metabolic acidosis: pCO2 ↓0.7 per 1 mEq/L HCO3- ↓"},
      "ph_low": {"threshold": "<7.3", "source": "Gal 2023", "mechanism": "Ketoacid accumulation (BHB, acetoacetate)"},
      "glucose_high": {"threshold": "≥250 mg/dL", "source": "Monnet 2014; Gal 2023", "mechanism": "Insulin deficiency → unrestrained gluconeogenesis + glycogenolysis"},
      "hco3_low": {"threshold": "<15 mEq/L", "source": "Gal 2023", "mechanism": "Buffering of ketoacids consumes HCO3-"},
      "dehydration": {"threshold": "5-10%", "source": "Gal 2023", "mechanism": "Osmotic diuresis from glycosuria"},
      "ketone_high": {"threshold": "BHB >3.8 mmol/L", "source": "Monnet 2014", "mechanism": "Hepatic ketogenesis from fatty acid oxidation"},
      "potassium_low": {"threshold": "<3.5 mEq/L", "source": "Hess 2013", "mechanism": "Osmotic diuresis loss + insulin-driven intracellular shift"}
    }
  },
