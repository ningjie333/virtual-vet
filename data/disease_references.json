        "journal": "JAVMA",
        "pmid": "8050972",
        "type": "retrospective"
      },
      {
        "authors": "Mooney E, Raw C, Hughes D",
        "year": 2014,
        "title": "Plasma lactate as prognostic biomarker in GDV",
        "journal": "Top Companion Anim Med",
        "doi": "10.1053/j.tcam.2014.09.005",
        "type": "prognostic"
      }
    ],
    "criteria": {
      "hr_high": {"threshold": "Tachycardia", "source": "Beck 2006", "mechanism": "Pain, hypovolemia, compensatory"},
      "hr_low": {"threshold": "Bradycardia (late)", "source": "Beck 2006", "mechanism": "Vagal stimulation from gastric distension"},
      "map_low": {"threshold": "Hypotension", "source": "Beck 2006", "mechanism": "Hypovolemic + obstructive shock"},
      "cvp_low": {"threshold": "Low CVP initially", "source": "Schertel 1997", "mechanism": "Hypovolemia"},
      "ph_low": {"threshold": "Lactic acidosis", "source": "Mooney 2014", "mechanism": "Tissue hypoperfusion → anaerobic metabolism"},
      "lactate_high": {"threshold": ">4 mmol/L", "source": "Mooney 2014", "mechanism": "Tissue ischemia; >6 = gastric necrosis likely"},
      "abdominal_distension": {"threshold": "Visible/tympanic", "source": "Rosselli 2022", "mechanism": "Gastric dilatation with gas accumulation"},
      "arrhythmia": {"threshold": "Ventricular arrhythmias", "source": "Pike 2022", "mechanism": "Myocardial ischemia, reperfusion injury; onset 12-36h post-surgery"}
    },
    "prognosis": {
      "lactate_lt4": "Better survival",
      "lactate_gt6": "Gastric necrosis more likely",
      "lactate_drop_40pct": "Good prognosis after fluids",
      "mortality": "16.2% (Beck 2006)",
      "high_risk_breeds": ["great_dane (OR 10.0)", "weimaraner (OR 4.6)", "saint_bernard (OR 4.2)"]
    }
  },
  "immune_mediated_hemolytic_anemia": {
    "guidelines": [
      {
        "authors": "Garden OA, Kidd L, Mexas AM, et al.",
        "year": 2019,
        "title": "ACVIM Consensus: Diagnosis of IMHA in Dogs and Cats",
        "journal": "J Vet Intern Med",
