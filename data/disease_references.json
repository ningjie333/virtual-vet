        "type": "consensus"
      }
    ],
    "criteria": {
      "hr_high": {"threshold": "Compensatory tachycardia", "source": "ACVIM 2020", "mechanism": "Reduced stroke volume → compensatory HR increase"},
      "hr_low": {"threshold": "Bradycardia if advanced", "source": "ACVIM 2020", "mechanism": "Myocardial failure, arrhythmias"},
      "map_low": {"threshold": "<90 mmHg", "source": "ACVIM 2020", "mechanism": "Reduced cardiac output → hypotension"},
      "cvp_high": {"threshold": "Elevated", "source": "ACVIM 2020", "mechanism": "Right heart failure → venous congestion"},
