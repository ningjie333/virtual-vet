        "type": "retrospective"
      }
    ],
    "criteria": {
      "hr_high": {"threshold": "Tachycardia", "source": "Gray 2011; Trakulsrichai 2017", "mechanism": "Compensatory response to hypotension + direct cardiotoxicity"},
      "hr_low": {"threshold": "Bradycardia (late)", "source": "Merck Vet Manual", "mechanism": "Myocardial depression from PH3"},
      "map_low": {"threshold": "Hypotension/shock", "source": "Gray 2011", "mechanism": "Vasodilation + myocardial depression"},
      "ph_low": {"threshold": "<7.35", "source": "PMC12322358", "mechanism": "High anion gap metabolic acidosis from impaired oxidative phosphorylation"},
      "temp_high": {"threshold": "Hyperthermia", "source": "Gray 2011", "mechanism": "Muscle tremors, seizures"},
      "temp_low": {"threshold": "Hypothermia (late)", "source": "Gray 2011", "mechanism": "Cardiovascular collapse"},
      "p_wave_absent": {"threshold": "Arrhythmia", "source": "Jadhav 2012; Singh 1991", "mechanism": "Myocardial necrosis from PH3"}
    },
    "mechanism": {
      "pathway": "Zn3P2 + 6HCl → 3ZnCl2 + 2PH3",
      "target": "Cytochrome C oxidase (Complex IV)",
      "effect": "Disrupts oxidative phosphorylation → cellular anoxia + ROS",
      "lethal_dose": "20-40 mg/kg",
      "toxic_dose": "2-4 mg/kg"
    }
  },
