        "doi": "10.1111/jvim.15463",
        "type": "consensus"
      }
    ],
    "diagnostic_criteria": {
      "required": "≥2 of 4 criteria",
      "criteria": [
        "Anemia (HCT <35%)",
        "Spherocytosis on blood smear",
        "Positive Coombs test (DAT)",
        "Autoagglutination (saline disaggregation test)"
      ]
    },
    "criteria": {
      "hr_high": {"threshold": "Tachycardia", "source": "ACVIM 2019", "mechanism": "Compensatory for anemia → reduced O2 carrying capacity"},
      "hct_low": {"threshold": "<35%, often <20%", "source": "ACVIM 2019", "mechanism": "Autoimmune RBC destruction"},
      "bilirubin_high": {"threshold": ">0.5 mg/dL", "source": "Goggs 2020", "mechanism": "Hemoglobin → heme → bilirubin from RBC destruction"},
      "icterus": {"threshold": "Visible at bilirubin >2.0 mg/dL", "source": "Goggs 2020", "mechanism": "Unconjugated bilirubin overwhelms hepatic conjugation"},
      "weak_pulse": {"threshold": "Reduced pulse quality", "source": "ACVIM 2019", "mechanism": "Reduced O2 delivery, possible hypotension"}
    },
    "transfusion_thresholds": {
      "no_signs": ">20%",
      "mild_signs": "15-20%",
      "moderate_severe": "<15-20%",
      "critical": "<12-15%"
    }
  },
