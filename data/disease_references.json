      "cardiomegaly_us": {"threshold": "FS% <20-25%", "source": "O'Grady 2008; Cornell 2004", "mechanism": "Systolic dysfunction"},
      "weak_pulse": {"threshold": "Reduced pulse pressure", "source": "ACVIM 2020", "mechanism": "Low stroke volume"},
      "qrs_wide": {"threshold": ">0.06s", "source": "O'Grady 2001", "mechanism": "Intraventricular conduction delay"}
