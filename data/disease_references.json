  "phosphorus_poisoning": {
    "guidelines": [
      {
        "authors": "Gray SL, Lee JA, Hovda LR, Brutlag AG",
        "year": 2011,
        "title": "Potential zinc phosphide rodenticide toxicosis in dogs: 362 cases",
