      "bladder_moderate": 0.4,
      "bladder_mild": 0.1,
      "pericardial_muffled": 0.3,
      "dic_organ_moderate": 0.5,
      "dic_organ_mild": 0.2
    },
    "tag_rules": [
      {
        "clue_id": "gfr_low",
        "condition": "state.GFR < thresholds.gfr_low_moderate"
      },
      {
        "clue_id": "lung_exudate_us",
        "condition": "disease.alveolar_exudate > thresholds.pneumonia_exudate",
        "requires": "disease.alveolar_exudate"
      },
      {
        "clue_id": "lung_exudate_us",
        "condition": "disease.fluid_retention > thresholds.dcm_fluid",
        "requires": "disease.fluid_retention"
      },
      {
        "clue_id": "cardiomegaly_us",
        "condition": "disease.ventricular_dilation > thresholds.dcm_dilation",
        "requires": "disease.ventricular_dilation"
      },
      {
        "clue_id": "bladder_distension",
        "condition": "disease.bladder_distension > thresholds.bladder_mild",
        "requires": "disease.bladder_distension"
      },
      {
        "clue_id": "anuria",
        "condition": "state.Urine < thresholds.urine_anuria"
      }
    ],
    "findings_rules": {
      "heart_function": [
        {"if": "state.contractility > thresholds.contractility_high", "text": "左室收缩功能增强（高动力状态）"},
        {"if": "state.contractility < thresholds.contractility_low", "text": "左室收缩功能减低，室壁运动减弱"},
        {"else": true, "text": "心脏结构正常，室壁运动良好"}
      ],
      "ivc_status": [
        {"if": "bv_ratio < thresholds.bv_low", "text": "下腔静脉塌陷（低血容量）"},
        {"if": "state.CVP > thresholds.cvp_high", "text": "下腔静脉扩张（容量过负荷/右心衰）"}
      ],
      "kidney_findings": [
        {"if": "state.GFR < thresholds.gfr_low_severe", "text": "双肾皮质回声增强（肾功能受损）"},
        {"if": "state.GFR < thresholds.gfr_low_moderate", "text": "肾血流灌注减少"},
        {"else": true, "text": "双肾大小正常，皮髓质分界清晰"}
      ],
      "dcm_heart": [
        {"if": "disease.ventricular_dilation > thresholds.dcm_dilation", "text": "左室扩张，室壁运动弥漫性减弱（DCM 表现）"},
        {"if": "disease.contractility_loss > thresholds.dcm_contractility_loss", "text": "左室缩短分数减低（收缩功能不全）"}
      ],
      "lung_findings": [
        {"if": "disease.alveolar_exudate > thresholds.pneumonia_exudate", "text": "肺实质样变（B线增多，胸膜线不规则）"},
        {"if": "disease.fluid_retention > thresholds.dcm_fluid", "text": "双肺B线增多（肺淤血/肺水肿）"}
      ],
      "urine_findings": [
        {"if": "state.Urine < thresholds.urine_anuria", "text": "无尿（尿量 {state.Urine:.4f} mL/min）"},
        {"if": "state.Urine < thresholds.urine_oliguria", "text": "少尿（尿量 {state.Urine:.4f} mL/min）"},
        {"else": true, "text": "尿量正常"}
      ],
      "bladder_findings": [
        {"if": "disease.bladder_distension > thresholds.bladder_severe", "text": "膀胱极度膨大，壁薄（尿道完全梗阻）"},
        {"if": "disease.bladder_distension > thresholds.bladder_moderate", "text": "膀胱明显膨大，需紧急导尿"},
        {"if": "disease.bladder_distension > thresholds.bladder_mild", "text": "膀胱中度充盈"}
      ],
      "pericardial_findings_us": [
        {"if": "disease.tamponade_severity > thresholds.pericardial_muffled", "text": "心包腔内可见液性暗区，右室舒张期塌陷（心脏填塞）"},
        {"if": "disease.pericardial_volume > 0.1", "text": "少量心包积液"}
      ],
      "dic_kidney_findings": [
        {"if": "disease.organ_ischemia > thresholds.dic_organ_moderate", "text": "双肾回声增强，皮髓质分界不清（肾微血栓缺血）"},
        {"if": "disease.organ_ischemia > thresholds.dic_organ_mild", "text": "肾血流灌注减少"}
      ]
    }
