{
  "_comment": "检查类型模板 — 驱动 report_engine 生成检查报告的配置",
  "_version": "1.1",
  "_schema": {
    "name": "显示名称",
    "test_type": "检查类型 ID（与 examinations.json 一致）",
    "handler": "生成器函数名（对应 report_engine._HANDLERS key）",
    "vitals": "定量参数列表（从 vitals_ranges.json 读取参考范围）",
    "extra_params": "非标准定量参数（如 Cr、ALT、USG 等自定义结果条目）",
    "tag_rules": "结构化标签规则 — 满足条件时 emit clue_id",
    "thresholds": "判断阈值 — 可在 tag_rules 和 findings_rules 中引用",
    "findings_rules": "叙述性检查的发现规则（仅叙述性检查使用）"
  },
  "physical": {
    "name": "体格检查",
    "test_type": "physical",
    "handler": "physical",
    "vitals": ["HR", "RR", "Temp", "MAP"],
    "extra_params": [],
    "thresholds": {
      "hr_tachy": 140,
      "hr_brady": 60,
      "map_low_severe": 50,
      "map_low_moderate": 65,
      "spo2_low_severe": 85,
      "spo2_low_moderate": 90,
      "mental_normal": "警觉/正常"
    },
    "tag_rules": [
      {
        "clue_id": "hr_high",
        "condition": "state.HR > thresholds.hr_tachy"
      },
      {
        "clue_id": "hr_low",
        "condition": "state.HR < thresholds.hr_brady"
      },
      {
        "clue_id": "rr_high",
        "condition": "state.RR > 30"
      },
      {
        "clue_id": "temp_high",
        "condition": "state.Temp > 39.2"
      },
      {
        "clue_id": "map_low",
        "condition": "state.MAP < thresholds.map_low_moderate"
      },
      {
        "clue_id": "SpO2_low",
        "condition": "state.Spo2 < thresholds.spo2_low_moderate"
      }
    ],
    "findings_rules": {
      "mental_status": [
        {"if": "state.MAP < thresholds.map_low_severe or state.SpO2 < thresholds.spo2_low_severe", "text": "昏迷"},
        {"if": "state.MAP < thresholds.map_low_moderate or state.SpO2 < thresholds.spo2_low_moderate", "text": "嗜睡/沉郁"},
        {"if": "state.HR > thresholds.hr_tachy", "text": "烦躁不安"},
        {"else": true, "text": "警觉/正常"}
      ]
    }
  },
  "auscultation": {
    "name": "听诊",
    "test_type": "auscultation",
    "handler": "auscultation",
    "vitals": [],
    "extra_params": [],
    "thresholds": {
      "hr_tachy": 140,
      "hr_brady": 50,
      "hr_very_high": 160,
      "rr_high": 35,
      "pao2_crackles_severe": 60,
      "pao2_crackles_mild": 80,
      "contractility_high": 1.3,
      "contractility_low": 0.7,
      "gdv_distension_severe": 0.7,
      "gdv_distension_moderate": 0.4,
      "gdv_distension_mild": 0.1,
      "kussmaul_moderate": 0.5,
      "kussmaul_mild": 0.2,
      "pericardial_muffled": 0.3,
      "arrhythmia_severe": 0.5
    },
    "tag_rules": [
      {
        "clue_id": "crackles",
        "condition": "state.PaO2 < thresholds.pao2_crackles_mild"
      },
      {
        "clue_id": "hr_high",
        "condition": "state.HR > thresholds.hr_tachy"
      },
      {
        "clue_id": "rr_high",
        "condition": "state.RR > thresholds.rr_high"
      },
      {
        "clue_id": "muffled_heart_sounds",
        "condition": "disease.tamponade_severity > thresholds.pericardial_muffled",
        "requires": "disease.tamponade_severity"
      },
      {
        "clue_id": "arrhythmia",
        "condition": "disease.arrhythmia_severity > thresholds.arrhythmia_severe",
        "requires": "disease.arrhythmia_severity"
      }
    ],
    "findings_rules": {
      "heart_rate_desc": [
        {"if": "state.HR > thresholds.hr_tachy", "text": "心动过速，心音增强"},
        {"if": "state.HR < thresholds.hr_brady", "text": "心动过缓，心音减弱"},
        {"else": true, "text": "心率正常，心音清晰"}
      ],
      "contractility_desc": [
        {"if": "state.contractility > thresholds.contractility_high", "text": "心音增强（高动力状态）"},
        {"if": "state.contractility < thresholds.contractility_low", "text": "心音低沉（收缩力减弱）"}
      ],
      "lung_desc": [
        {"if": "state.PaO2 < thresholds.pao2_crackles_severe", "text": "双肺湿啰音（肺泡渗出）"},
        {"if": "state.PaO2 < thresholds.pao2_crackles_mild", "text": "肺底细湿啰音"},
        {"if": "state.RR > thresholds.rr_high", "text": "呼吸音粗粝（呼吸急促）"},
        {"else": true, "text": "肺音清晰，呼吸音正常"}
      ],
      "rhythm_note": [
        {"if": "state.HR > thresholds.hr_very_high", "text": "节律不齐待排（建议心电图）"}
      ],
      "gdv_findings": [
        {"if": "disease.gastric_distension > thresholds.gdv_distension_severe", "text": "心音遥远（胃扩张压迫膈肌），可闻及振水音"},
        {"if": "disease.gastric_distension > thresholds.gdv_distension_moderate", "text": "心音轻度遥远"},
        {"if": "disease.arrhythmia_severity > thresholds.arrhythmia_severe", "text": "室性早搏（胃扩张扭转常见并发症）"}
      ],
      "dka_kussmaul": [
        {"if": "disease.kussmaul_respiration > thresholds.kussmaul_moderate", "text": "深大呼吸（Kussmaul呼吸），呼气有酮味"},
        {"if": "disease.kussmaul_respiration > thresholds.kussmaul_mild", "text": "呼吸深快"}
      ],
      "pericardial_findings": [
        {"if": "disease.tamponade_severity > thresholds.pericardial_muffled", "text": "心音遥远、低沉（心脏填塞征象）"},
        {"if": "disease.pulsus_paradoxus > 0.3", "text": "奇脉（吸气时心音明显减弱）"}
      ],
      "dic_hemorrhage": [
        {"if": "disease.hemorrhage_risk > thresholds.dic_hemorrhage_moderate", "text": "黏膜出血点，静脉穿刺部位渗血不止"},
        {"if": "disease.hemorrhage_risk > thresholds.dic_hemorrhage_mild", "text": "散在瘀点瘀斑"}
      ],
      "icterus_note": [
        {"if": "disease.bilirubin_load > thresholds.icterus_moderate", "text": "黏膜黄染（重度黄疸）"},
        {"if": "disease.bilirubin_load > thresholds.icterus_mild", "text": "黏膜轻度黄染"}
      ],
      "pericardial_jvd": [
        {"if": "disease.venous_congestion > thresholds.jvd_moderate", "text": "颈静脉怒张（平卧位仍明显）"},
        {"if": "disease.venous_congestion > thresholds.jvd_mild", "text": "颈静脉轻度充盈"}
      ]
    }
  },
  "inspection": {
    "name": "视诊",
    "test_type": "inspection",
    "handler": "inspection",
    "vitals": [],
    "extra_params": [],
    "thresholds": {
      "spo2_cyanosis_severe": 85,
      "spo2_cyanosis_mild": 92,
      "map_low": 60,
      "bv_dehydration_severe": 0.85,
      "bv_dehydration_moderate": 0.92,
      "bv_dehydration_mild": 0.97,
      "temp_high": 39.5,
      "temp_very_high": 40.0,
      "temp_low": 37.5,
      "gdv_distension_severe": 0.7,
      "gdv_distension_moderate": 0.4,
      "gdv_distension_mild": 0.1,
      "kussmaul_moderate": 0.5,
      "kussmaul_mild": 0.2,
      "icterus_moderate": 0.5,
      "icterus_mild": 0.15,
      "jvd_moderate": 0.5,
      "jvd_mild": 0.2,
      "dic_hemorrhage_moderate": 0.5,
      "dic_hemorrhage_mild": 0.2
    },
    "tag_rules": [
      {
        "clue_id": "SpO2_low",
        "condition": "state.SpO2 < thresholds.spo2_cyanosis_mild"
      },
      {
        "clue_id": "dehydration",
        "condition": "bv_ratio < thresholds.bv_dehydration_moderate"
      },
      {
        "clue_id": "icterus",
        "condition": "disease.bilirubin_load > thresholds.icterus_mild",
        "requires": "disease.bilirubin_load"
      },
      {
        "clue_id": "jugular_distension",
        "condition": "disease.venous_congestion > thresholds.jvd_mild",
        "requires": "disease.venous_congestion"
      },
      {
        "clue_id": "petechiae",
        "condition": "disease.hemorrhage_risk > thresholds.dic_hemorrhage_mild",
        "requires": "disease.hemorrhage_risk"
      }
    ],
    "findings_rules": {
      "mucosa_color": [
        {"if": "state.SpO2 < thresholds.spo2_cyanosis_severe", "text": "黏膜发绀（严重低氧）"},
        {"if": "state.SpO2 < thresholds.spo2_cyanosis_mild", "text": "黏膜轻度发绀"},
        {"if": "state.MAP < thresholds.map_low", "text": "黏膜苍白（低灌注）"},
        {"else": true, "text": "黏膜颜色正常，粉红色"}
      ],
      "hydration": [
        {"if": "bv_ratio < thresholds.bv_dehydration_severe", "text": "重度脱水（皮肤弹性差，眼球凹陷）"},
        {"if": "bv_ratio < thresholds.bv_dehydration_moderate", "text": "中度脱水（皮肤弹性下降）"},
        {"if": "bv_ratio < thresholds.bv_dehydration_mild", "text": "轻度脱水"},
        {"else": true, "text": "水合状态正常"}
      ],
      "temperature_note": [
        {"if": "state.Temp > thresholds.temp_very_high", "text": "高热（体温 {state.Temp:.1f}°C）"},
        {"if": "state.Temp > thresholds.temp_high", "text": "发热（体温 {state.Temp:.1f}°C）"},
        {"if": "state.Temp < thresholds.temp_low", "text": "低体温（体温 {state.Temp:.1f}°C）"}
      ],
      "gdv_abdomen": [
        {"if": "disease.gastric_distension > thresholds.gdv_distension_severe", "text": "腹部极度膨隆如鼓，腹壁紧张"},
        {"if": "disease.gastric_distension > thresholds.gdv_distension_moderate", "text": "腹部明显膨隆，叩诊呈鼓音"},
        {"if": "disease.gastric_distension > thresholds.gdv_distension_mild", "text": "上腹部轻度膨隆"}
      ],
      "icterus_findings": [
        {"if": "disease.bilirubin_load > thresholds.icterus_moderate", "text": "黏膜重度黄染（黄疸）"},
        {"if": "disease.bilirubin_load > thresholds.icterus_mild", "text": "黏膜轻度黄染"},
        {"else": true, "text": "黏膜颜色正常，无黄疸"}
      ],
      "dic_hemorrhage_findings": [
        {"if": "disease.hemorrhage_risk > thresholds.dic_hemorrhage_moderate", "text": "全身多处瘀斑，穿刺部位渗血不止，可见血便"},
        {"if": "disease.hemorrhage_risk > thresholds.dic_hemorrhage_mild", "text": "散在瘀点瘀斑"}
      ],
      "jvd_findings": [
        {"if": "disease.venous_congestion > thresholds.jvd_moderate", "text": "颈静脉怒张（平卧位仍明显）"},
        {"if": "disease.venous_congestion > thresholds.jvd_mild", "text": "颈静脉轻度充盈"}
      ],
      "kussmaul_finding": [
        {"if": "disease.kussmaul_respiration > thresholds.kussmaul_moderate", "text": "深大呼吸（Kussmaul呼吸），呼气有酮味"},
        {"if": "disease.kussmaul_respiration > thresholds.kussmaul_mild", "text": "呼吸深快"}
      ]
    }
  },
  "blood_routine": {
    "name": "血常规",
    "test_type": "blood_routine",
    "handler": "blood_routine",
    "vitals": ["HCT"],
    "extra_params": [
      {
        "param": "WBC",
        "unit": "×10⁹/L",
        "normal_range": "6.0-17.0",
        "source": "computed",
        "value_formula": "thresholds.wbc_base + (disease.bacterial_load * thresholds.wbc_bacterial_factor if getattr(disease, 'active', False) and hasattr(disease, 'bacterial_load') else 0)"
      },
      {
        "param": "PLT",
        "unit": "×10⁹/L",
        "normal_range": "150-500",
        "source": "creature.blood.PLT"
      }
    ],
    "thresholds": {
      "wbc_base": 12.0,
      "wbc_bacterial_factor": 8.0
    },
    "tag_rules": [
      {
        "clue_id": "wbc_high",
        "condition": "state.WBC > 17.0"
      },
      {
        "clue_id": "hct_low",
        "condition": "state.HCT < 37.0"
      },
      {
        "clue_id": "plt_low",
        "condition": "state.PLT < 150.0"
      }
    ],
    "findings_rules": {}
  },
  "blood_coagulation": {
    "name": "凝血功能检查",
    "test_type": "blood_coagulation",
    "handler": "blood_coagulation",
    "vitals": [],
    "extra_params": [
      {
        "param": "PT",
        "unit": "秒",
        "normal_range": "10-14",
        "source": "creature.blood.PT_sec"
      },
      {
        "param": "aPTT",
        "unit": "秒",
        "normal_range": "25-35",
        "source": "creature.blood.aPTT_sec"
      },
      {
        "param": "Fibrinogen",
        "unit": "mg/dL",
        "normal_range": "200-400",
        "source": "creature.blood.fibrinogen_mg_dL"
      }
    ],
    "thresholds": {
      "pt_prolonged": 14.0,
      "pt_severely_prolonged": 20.0,
      "aptt_prolonged": 35.0,
      "aptt_severely_prolonged": 50.0,
      "fibrinogen_low": 150.0,
      "fibrinogen_very_low": 100.0,
      "coag_state_dic": 0.5
    },
    "tag_rules": [
      {
        "clue_id": "pt_prolonged",
        "condition": "state.PT > thresholds.pt_prolonged"
      },
      {
        "clue_id": "aptt_prolonged",
        "condition": "state.aPTT > thresholds.aptt_prolonged"
      },
      {
        "clue_id": "fibrinogen_low",
        "condition": "state.Fibrinogen < thresholds.fibrinogen_low"
      }
    ],
    "findings_rules": {
      "pt_interpretation": [
        {
          "if": "state.PT <= thresholds.pt_prolonged",
          "text": "PT正常"
        },
        {
          "if": "state.PT > thresholds.pt_prolonged and state.PT <= thresholds.pt_severely_prolonged",
          "text": "PT轻度延长（凝血因子轻度不足）"
        },
        {
          "if": "state.PT > thresholds.pt_severely_prolonged",
          "text": "PT显著延长（严重凝血障碍）"
        }
      ],
      "aptt_interpretation": [
        {
          "if": "state.aPTT <= thresholds.aptt_prolonged",
          "text": "aPTT正常"
        },
        {
          "if": "state.aPTT > thresholds.aptt_prolonged and state.aPTT <= thresholds.aptt_severely_prolonged",
          "text": "aPTT延长（内源性凝血途径因子缺乏）"
        },
        {
          "if": "state.aPTT > thresholds.aptt_severely_prolonged",
          "text": "aPTT显著延长（严重凝血障碍）"
        }
      ],
      "fibrinogen_interpretation": [
        {
          "if": "state.Fibrinogen >= thresholds.fibrinogen_low",
          "text": "纤维蛋白原正常"
        },
        {
          "if": "state.Fibrinogen < thresholds.fibrinogen_low and state.Fibrinogen >= thresholds.fibrinogen_very_low",
          "text": "纤维蛋白原轻度降低"
        },
        {
          "if": "state.Fibrinogen < thresholds.fibrinogen_very_low",
          "text": "纤维蛋白原严重降低（消耗性凝血障碍可能）"
        }
      ]
    }
  },
  "blood_biochem": {
    "name": "生化全项",
    "test_type": "blood_biochem",
    "handler": "blood_biochem",
    "vitals": ["BUN", "Glu", "Na", "K"],
    "extra_params": [
      {
        "param": "Cr",
        "unit": "mg/dL",
        "normal_range": "0.5-1.5",
        "source": "creature.blood.creatinine_mg_dL"
      },
      {
        "param": "ALT",
        "unit": "U/L",
        "normal_range": "10-100",
        "source": "hardcoded",
        "default_value": 45.0
      },
      {
        "param": "Bilirubin",
        "unit": "mg/dL",
        "normal_range": "<0.5",
        "source": "creature.blood.bilirubin_mg_dL"
      },
      {
        "param": "Ketone",
        "unit": "mmol/L",
        "normal_range": "<0.5",
        "source": "creature.blood.ketone_mmol_L"
      }
    ],
    "thresholds": {},
    "tag_rules": [
      {
        "clue_id": "bun_high",
        "condition": "state.BUN > 30.0"
      },
      {
        "clue_id": "gfr_low",
        "condition": "state.GFR < 60.0",
        "note": "GFR 来自 vitals 而非 extra_params"
      },
      {
        "clue_id": "potassium_high",
        "condition": "state.K > 5.5"
      },
      {
        "clue_id": "potassium_low",
        "condition": "state.K < 3.5"
      },
      {
        "clue_id": "cr_high",
        "condition": "creature.blood.creatinine_mg_dL > 1.5"
      },
      {
        "clue_id": "glucose_high",
        "condition": "state.Glu > 10.0"
      },
      {
        "clue_id": "bilirubin_high",
        "condition": "creature.blood.bilirubin_mg_dL > 0.5"
      },
      {
        "clue_id": "ketone_high",
        "condition": "creature.blood.ketone_mmol_L > 0.5"
      }
    ]
  },
  "blood_gas": {
    "name": "血气分析",
    "test_type": "blood_gas",
    "handler": "blood_gas",
    "vitals": ["PaO2", "PaCO2", "pH", "Lactate", "SpO2", "HCO3"],
    "extra_params": [],
    "thresholds": {
      "ph_acidosis": 7.35,
      "ph_alkalosis": 7.45,
      "paco2_high": 45,
      "paco2_low": 35,
      "lactate_high": 2.5,
      "hco3_low": 18,
      "hco3_very_low": 12,
      "paco2_kussmaul_low": 30
    },
    "tag_rules": [
      {
        "clue_id": "PaO2_low",
        "condition": "state.PaO2 < 80.0"
      },
      {
        "clue_id": "PaCO2_high",
        "condition": "state.PaCO2 > thresholds.paco2_high"
      },
      {
        "clue_id": "SpO2_low",
        "condition": "state.SpO2 < 95.0"
      },
      {
        "clue_id": "ph_low",
        "condition": "state.pH < thresholds.ph_acidosis"
      },
      {
        "clue_id": "ph_high",
        "condition": "state.pH > thresholds.ph_alkalosis"
      },
      {
        "clue_id": "lactate_high",
        "condition": "state.Lactate > thresholds.lactate_high"
      },
      {
        "clue_id": "hco3_low",
        "condition": "state.HCO3 < thresholds.hco3_low"
      }
    ],
    "findings_rules": {
      "acidosis_type": [
        {"if": "state.pH < thresholds.ph_acidosis and state.PaCO2 > thresholds.paco2_high", "text": "呼吸性酸中毒"},
        {"if": "state.pH < thresholds.ph_acidosis and state.Lactate > thresholds.lactate_high", "text": "代谢性酸中毒（乳酸酸中毒）"},
        {"if": "state.pH < thresholds.ph_acidosis and state.HCO3 < thresholds.hco3_very_low", "text": "代谢性酸中毒（酮症酸中毒可能）"},
        {"if": "state.pH < thresholds.ph_acidosis and state.HCO3 < thresholds.hco3_low", "text": "代谢性酸中毒"},
        {"if": "state.pH < thresholds.ph_acidosis", "text": "酸中毒"}
      ],
      "alkalosis_type": [
        {"if": "state.pH > thresholds.ph_alkalosis and state.PaCO2 < thresholds.paco2_low", "text": "呼吸性碱中毒"},
        {"if": "state.pH > thresholds.ph_alkalosis", "text": "碱中毒"}
      ],
      "kussmaul_compensation": [
        {"if": "state.pH < thresholds.ph_acidosis and state.PaCO2 < thresholds.paco2_kussmaul_low", "text": "呼吸代偿（Kussmaul呼吸，CO2代偿性降低）"}
      ]
    }
  },
  "chest_xray": {
    "name": "X光胸片",
    "test_type": "chest_xray",
    "handler": "chest_xray",
    "vitals": [],
    "extra_params": [],
    "thresholds": {
      "exudate_severe": 0.7,
      "exudate_moderate": 0.3,
      "exudate_mild": 0.05,
      "hypoxia_severe": 0.5,
      "dcm_dilation": 0.3,
      "dcm_fluid": 0.3,
      "rr_high": 35,
      "pao2_low": 80
    },
    "tag_rules": [
      {
        "clue_id": "lung_exudate_xray",
        "condition": "disease.alveolar_exudate > thresholds.exudate_mild",
        "requires": "disease.alveolar_exudate"
      },
      {
        "clue_id": "cardiomegaly_xray",
        "condition": "disease.ventricular_dilation > thresholds.dcm_dilation",
        "requires": "disease.ventricular_dilation"
      }
    ],
    "findings_rules": {
      "pneumonia_findings": [
