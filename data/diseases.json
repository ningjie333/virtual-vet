  "messages": {
    "win": {
      "pneumonia": "正确诊断！补液治疗后，患犬的循环状态和氧合逐渐改善。",
      "acute_renal_failure": "正确诊断！积极补液恢复肾灌注后，患犬的肾功能指标开始好转。",
      "dilated_cardiomyopathy": "正确诊断！强心（匹莫苯丹）+ 利尿（呋塞米）治疗后，患犬心功能逐渐改善，呼吸困难缓解。",
      "phosphorus_poisoning": "正确诊断！积极补液和支持治疗后，患犬的中毒症状逐渐缓解，体温和心律趋于稳定。",
      "gastric_dilatation_volvulus": "正确诊断！紧急补液稳定循环后，患犬顺利接受手术复位，胃壁血供恢复。",
      "immune_mediated_hemolytic_anemia": "正确诊断！免疫抑制治疗和输血后，患犬的溶血得到控制，HCT开始回升。",
      "urinary_obstruction": "正确诊断！紧急导尿排除膀胱蓄积尿液后，患犬的高钾和酸中毒迅速纠正。",
      "diabetic_ketoacidosis": "正确诊断！积极补液+胰岛素治疗后，患犬的血糖和酮体逐渐恢复正常，酸中毒纠正。",
      "pericardial_effusion": "正确诊断！心包穿刺引流后，患犬的心脏填塞症状迅速缓解，血压回升。",
      "disseminated_intravascular_coagulation": "正确诊断！积极补液+抗凝+输血支持治疗后，患犬的凝血功能逐渐恢复。",
      "hepatic_failure_coagulopathy": "正确诊断！维生素K1止血+输液支持后，患犬的凝血功能逐渐改善。",
      "splenic_rupture": "正确诊断！紧急输液扩容+配血后，患犬的休克症状得到纠正。",
      "hyperthyroidism": "正确诊断！抗甲状腺药物（甲巯咪唑）治疗后，T3水平逐渐恢复正常，心率和体温回落。",
      "hypoadrenocorticism": "正确诊断！补液纠正电解质紊乱+糖皮质激素替代治疗后，患犬的精神状态和食欲明显改善。",
      "sepsis": "正确诊断！积极液体复苏+广谱抗生素治疗后，感染得到控制，生命体征趋于稳定。",
      "ivdd": "正确诊断！镇痛消炎治疗后，患犬的疼痛症状明显缓解，活动能力逐渐恢复。",
      "meningitis": "正确诊断！抗炎+抗惊厥治疗后，患犬的神经症状逐渐改善，意识恢复正常。",
      "ckd_anemia": "正确诊断！促红细胞生成素+补铁+液体支持治疗后，贫血和氮质血症逐渐改善。",
      "hepatic_anemia": "正确诊断！保肝+输血支持治疗后，肝功能指标和贫血逐渐改善。"
    },
    "loss": {
      "pneumonia": "误诊！患犬的呼吸系统症状提示存在感染性病变，请重新评估肺部检查。",
      "acute_renal_failure": "误诊！患犬的氮质血症和电解质紊乱提示泌尿系统出了问题，请复查肾功能和尿液。",
      "dilated_cardiomyopathy": "误诊！患犬的心脏扩大伴收缩功能下降，提示心肌病变，请复查心脏超声和心电图。",
      "phosphorus_poisoning": "误诊！患犬的中毒症状（心律紊乱、体温异常、低血压）提示毒性物质暴露，请进行毒物筛查。",
      "gastric_dilatation_volvulus": "误诊！患犬的急性腹痛、休克和腹部膨隆提示胃部急症，请紧急评估腹部X光和超声。",
      "immune_mediated_hemolytic_anemia": "误诊！患犬的严重贫血伴黄疸提示溶血性疾病，请复查血常规和细胞学。",
      "urinary_obstruction": "误诊！患犬的无尿、高钾和酸中毒提示尿道梗阻，请紧急导尿并复查尿液。",
      "diabetic_ketoacidosis": "误诊！患犬的高血糖、酮症酸中毒和Kussmaul呼吸提示代谢危象，请复查血糖和血气。",
      "pericardial_effusion": "误诊！患犬的颈静脉怒张、心音遥远和奇脉提示心包积液，请紧急心脏超声。",
      "disseminated_intravascular_coagulation": "误诊！患犬的多部位出血、血小板减少和休克提示凝血功能障碍，请复查凝血功能。",
      "hepatic_failure_coagulopathy": "误诊！患犬的凝血功能异常和低白蛋白血症提示肝脏合成功能下降，请复查肝功能和凝血指标。",
      "splenic_rupture": "误诊！患犬的失血性休克和腹部症状提示腹腔出血，请紧急腹部超声和血常规复查。",
      "hyperthyroidism": "误诊！患猫的体重下降、心率加快和高代谢状态提示内分泌疾病，请复查甲状腺功能（T3/T4）。",
      "hypoadrenocorticism": "误诊！患犬的虚弱、低血压和高钾低钠提示肾上腺皮质功能不全，请复查电解质和ACTH刺激试验。",
      "sepsis": "误诊！患犬的发热、低血压和灌注不良提示全身性感染，请进行血培养和感染灶排查。",
      "ivdd": "误诊！患犬的运动疼痛和活动受限提示脊柱疾病，请进行神经系统检查和影像学评估。",
      "meningitis": "误诊！患犬的意识改变、癫痫和发热提示中枢神经系统感染，请进行脑脊液分析和神经影像学检查。",
      "ckd_anemia": "误诊！患犬的贫血伴氮质血症提示慢性肾脏病，请复查肾功能、血常规和血压。",
      "hepatic_anemia": "误诊！患犬的贫血伴肝酶升高和低白蛋白血症提示肝脏疾病，请复查肝功能和腹部超声。"
    }
  }
}
