{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://virtual-vet.app/schemas/diseases.schema.json",
  "title": "Diseases Schema",
  "description": "Schema for data/diseases.json - disease definitions, clues, and treatments",
  "type": "object",
  "required": ["disease_names", "clues", "clue_descriptions", "clue_to_test", "treatment_protocols", "messages"],
  "properties": {
    "disease_names": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "clues": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "clue_descriptions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "clue_to_test": {
      "type": "object",
      "deprecated": true,
      "description": "DEPRECATED as of Wave 4 (2026-06-11). The clue-to-test mapping is migrating into data/clue_catalog.json::suggested_tests. This field is retained during the migration period so that game/diagnosis_engine.py still has the diagnostic-side recommendations; once the catalog becomes the runtime source, this field will be removed and the diseases.schema.json will reject it. Per Q3 decision in docs/clue-trigger-plan.md, no override mechanism is permitted.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    },
    "treatment_protocols": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["drug_name"],
          "properties": {
            "drug_name": {
              "type": "string"
            },
            "dose_mg_kg": {
              "type": "number"
            },
            "volume_ml": {
              "type": "number"
            }
          }
        }
      }
    },
    "messages": {
      "type": "object",
      "required": ["win", "loss"],
      "properties": {
        "win": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "loss": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}