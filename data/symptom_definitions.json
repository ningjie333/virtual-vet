      "evaluation_type": "instantaneous",
      "rule_type": "threshold",
      "param": "disease.coagulation_consumption",
      "threshold": 0.3,
      "rule": "disease.coagulation_consumption > 0.3",
      "clue_id": "dic_sign",
      "description": "DIC: 凝血因子消耗 → 广泛出血倾向（瘀点、瘀斑、注射部位渗血、消化道出血）"
    },
    "dic_shock_sign": {
