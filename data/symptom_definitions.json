      "param": "disease.pericardial_volume",
      "threshold": 0.3,
      "rule": "disease.pericardial_volume > 0.3",
      "clue_id": "pericardial_effusion_sign",
      "description": "心包积液: 心包腔液体积蓄 → 超声可见游离液体，心音因液体阻隔而低沉"
    },
    "jvd_sign": {
      "display_name": "颈静脉怒张",
      "type": "observable",
      "evaluation_type": "instantaneous",
      "rule_type": "threshold",
      "param": "disease.venous_congestion",
      "threshold": 0.3,
      "rule": "disease.venous_congestion > 0.3",
      "clue_id": "jvd_sign",
      "description": "心包积液: 右心回流受阻 → 颈静脉怒张（区别于jugular_distension规则用阈值0.2，更严格0.3）"
    },
    "dic_sign": {
      "display_name": "凝血功能障碍/出血倾向",
