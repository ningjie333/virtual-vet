      "rule": "disease.shock_from_dIC > 0.3 AND MAP < map_hypotension",
      "clue_id": "dic_shock_sign",
      "description": "DIC休克: 微血栓广泛形成+出血 → 循环衰竭（MAP<60mmHg），预后不良"
    },
    "coag_sign_hepatic": {
      "display_name": "凝血酶原时间延长",
